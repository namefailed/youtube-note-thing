# Copy this file to ".env" (which is gitignored) and fill in your values.
# Never commit real secrets — ".env" stays out of git; CI uses GitHub secrets.

# The app's built-in Google OAuth "Desktop app" client (YouTube Data API v3
# enabled). Compiled into the binary so users can "Connect YouTube" without
# registering their own client. Leave blank to require each user to add their own.
YTNT_GOOGLE_CLIENT_ID=
YTNT_GOOGLE_CLIENT_SECRET=
